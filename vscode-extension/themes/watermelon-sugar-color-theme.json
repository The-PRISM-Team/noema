    "menu.selectionForeground": "#ffffff",

    "checkbox.background": "#43254f",
    "checkbox.foreground": "#ffc0cb",

    "peekViewEditor.background": "#43254f"
  },
  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#aa8899", "fontStyle": "italic" }
    },
    {
      "scope": ["string"],
      "settings": { "foreground": "#4cff88" }
    },
    {
      "scope": ["keyword", "storage"],
      "settings": { "foreground": "#ff4c4c", "fontStyle": "bold" }
    },
    {
      "scope": ["entity.name.function", "support.function", "entity.name.type"],
      "settings": { "foreground": "#ffc0cb", "fontStyle": "bold" }
    },
    {
      "scope": ["variable", "identifier"],
      "settings": { "foreground": "#ffc0cb" }
    }
  ]
}