    "titleBar.inactiveBackground": "#2a1733",
    "titleBar.inactiveForeground": "#aa8899",

    "tab.activeBackground": "#43254f",
    "tab.inactiveBackground": "#341c3e",
    "tab.hoverBackground": "#ff4c4c50",
    "tab.activeForeground": "#ffc0cb",
    "tab.inactiveForeground": "#aa8899",
    "tab.border": "#ff4c4c",
    "tab.activeBorder": "#4cff88",

    "panel.background": "#341c3e",
    "panel.border": "#ff4c4c",
    "panelTitle.activeForeground": "#ffc0cb",

    "input.background": "#43254f",
    "input.foreground": "#ffc0cb",
